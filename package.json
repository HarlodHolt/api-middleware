{
  "name": "api-middleware",
  "version": "1.0.0",
  "description": "Shared API middleware for Olive & Ivory Apps/Workers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "MIGRATION.md"
  ],
  "devDependencies": {
    "@types/node": "^20.19.13",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test ./tests/api-middleware.test.ts"
  },
  "dependencies": {
    "hono": "^4.12.3"
  }
}
