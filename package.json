{
  "name": "api-middleware",
  "version": "0.1.2",
  "description": "Edge-safe middleware pipeline for Next.js, Cloudflare Workers/Pages, and Hono",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "MIGRATION.md", "package.json"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "prepare": "npm run build",
    "lint": "biome check biome.json package.json tsconfig.json README.md MIGRATION.md src tests scripts examples .github/workflows",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test ./tests/*.test.ts",
    "db:check": "node scripts/check-db-schema-drift.mjs",
    "test:prepush": "node scripts/local-test-harness.mjs",
    "test:ci": "npm run lint && npm run typecheck && npm run db:check && npm run test && npm run build",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "test:harness": "node scripts/local-test-harness.mjs",
    "test:harness:full": "node scripts/local-test-harness.mjs --full",
    "guard:runtime": "node --import tsx scripts/check-runtime-imports.ts",
    "pack:check": "npm pack --dry-run",
    "ai:rules:check": "node scripts/ci-enforce-ai-rules.mjs",
    "ai:pr:check": "node scripts/validate-pr-template.mjs"
  },
  "dependencies": {
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.19.13",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
